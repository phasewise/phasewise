generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Organizations (firms) ─────────────────────────────────────────────

model Organization {
  id                       String              @id @default(uuid()) @db.Uuid
  name                     String
  slug                     String              @unique
  plan                     Plan                @default(TRIAL)
  stripeCustomerId         String?             @unique @map("stripe_customer_id")
  stripeSubscriptionId     String?             @unique @map("stripe_subscription_id")
  stripePriceId            String?             @map("stripe_price_id")
  subscriptionStatus       SubscriptionStatus? @map("subscription_status")
  currentPeriodEnd         DateTime?           @map("current_period_end")
  cancelAtPeriodEnd        Boolean             @default(false) @map("cancel_at_period_end")
  trialEndsAt              DateTime?           @map("trial_ends_at")
  projectNumberPrefix      String              @default("PW") @map("project_number_prefix")
  projectNumberNext        Int                 @default(1) @map("project_number_next")
  autoNumberProjects       Boolean             @default(true) @map("auto_number_projects")
  // Invoice numbering — same pattern as project numbering. Counter is
  // incremented inside a transaction on create so two simultaneous
  // requests don't both produce INV-N.
  invoiceNumberPrefix      String              @default("INV") @map("invoice_number_prefix")
  invoiceNumberNext        Int                 @default(1) @map("invoice_number_next")
  autoNumberInvoices       Boolean             @default(true) @map("auto_number_invoices")
  leavePolicy              Json?               @map("leave_policy")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  users       User[]
  projects    Project[]
  invitations Invitation[]
  timeEntries TimeEntry[]
  clients     Client[]
  invoices    Invoice[]

  @@map("organizations")
}

enum Plan {
  TRIAL
  STARTER
  PROFESSIONAL
  STUDIO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

// ── Users ─────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid()) @db.Uuid
  authId          String   @unique @map("auth_id") // Supabase auth.users.id
  organizationId  String   @map("organization_id") @db.Uuid
  fullName        String   @map("full_name")
  email           String
  role            UserRole @default(STAFF)
  title           String?  // Display title (e.g., "Senior Associate", "Landscape Architect")
  phone           String?  // Contact phone number
  photoUrl        String?  @map("photo_url") // Profile photo URL (Supabase Storage)
  billingRate     Decimal? @map("billing_rate") @db.Decimal(10, 2)
  salary          Decimal? @map("salary") @db.Decimal(12, 2) // Annual salary — OWNER/ADMIN only
  costRate        Decimal? @map("cost_rate") @db.Decimal(10, 2) // Hourly cost (salary / 2080)
  leavePolicyOverride Json? @map("leave_policy_override")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timeEntries  TimeEntry[]
  createdProjects Project[] @relation("ProjectCreator")
  approvedTimesheets WeeklyTimesheet[] @relation("TimesheetApprover")
  timesheets   WeeklyTimesheet[]
  assignments ProjectAssignment[]
  assignedTasks ProjectTask[]
  phaseStaffPlans PhaseStaffPlan[]
  createdSubmittals Submittal[] @relation("SubmittalCreator")
  assignedSubmittals Submittal[] @relation("SubmittalAssignee")

  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  SUPERVISOR
  PM
  STAFF
}

// ── Invitations ───────────────────────────────────────────────────────

model Invitation {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  email           String
  role            UserRole @default(STAFF)
  token           String   @unique @default(uuid())
  expiresAt       DateTime @map("expires_at")
  acceptedAt      DateTime? @map("accepted_at")
  createdAt       DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

// ── Projects ──────────────────────────────────────────────────────────

model Project {
  id               String        @id @default(uuid()) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  name             String
  projectNumber    String?       @map("project_number")
  clientId         String?       @map("client_id") @db.Uuid
  clientName       String?       @map("client_name")
  clientEmail      String?       @map("client_email")
  status           ProjectStatus @default(ACTIVE)
  startDate        DateTime?     @map("start_date") @db.Date
  targetCompletion DateTime?     @map("target_completion") @db.Date
  contractFee      Decimal?      @map("contract_fee") @db.Decimal(12, 2)
  description      String?
  // Free-text city/locality and project type so firms can use whatever
  // taxonomy they want (residential / commercial / public / entry
  // monument / features / parks / etc.). Used by list-view filters.
  city             String?
  projectType      String?       @map("project_type")
  createdById      String        @map("created_by_id") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User           @relation("ProjectCreator", fields: [createdById], references: [id])
  client       Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  phases       ProjectPhase[]
  assignments  ProjectAssignment[]
  tasks        ProjectTask[]
  timeEntries     TimeEntry[]
  submittals      Submittal[]
  plantEntries    PlantEntry[]
  complianceItems ComplianceItem[]
  invoices        Invoice[]
  billingEvents   BillingEvent[]
  budgetAlerts    BudgetAlert[]

  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model ProjectAssignment {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  assignedAt    DateTime @default(now()) @map("assigned_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_assignments")
}

model ProjectTask {
  id            String      @id @default(uuid()) @db.Uuid
  projectId     String      @map("project_id") @db.Uuid
  assignedToId  String?     @map("assigned_to_id") @db.Uuid
  name          String
  description   String?
  dueDate       DateTime?   @map("due_date") @db.Date
  status        TaskStatus  @default(NOT_STARTED)
  completedAt   DateTime?   @map("completed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@map("project_tasks")
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

// ── Project Phases ────────────────────────────────────────────────────

model ProjectPhase {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @map("project_id") @db.Uuid
  phaseType     PhaseType @map("phase_type")
  customName    String?   @map("custom_name") // Override display name for standard types, or the name for OTHER type
  status        PhaseStatus @default(NOT_STARTED)
  budgetedFee   Decimal?  @map("budgeted_fee") @db.Decimal(12, 2)
  budgetedHours Decimal?  @map("budgeted_hours") @db.Decimal(8, 2)
  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  sortOrder     Int       @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")

  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries   TimeEntry[]
  workPlan      PhaseStaffPlan[]

  @@map("project_phases")
}

// ── Clients ─────────────────────────────────────────────────────────

model Client {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String   // Company or individual name
  contactPerson   String?  @map("contact_person")
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  zip             String?
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]

  @@map("clients")
}

// ── Submittals & RFIs ────────────────────────────────────────────────

model Submittal {
  id              String           @id @default(uuid()) @db.Uuid
  projectId       String           @map("project_id") @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  type            SubmittalType    @default(SUBMITTAL)
  number          String           // e.g., "SUB-001", "RFI-003"
  subject         String
  description     String?
  status          SubmittalStatus  @default(PENDING)
  ballInCourt     String?          @map("ball_in_court") // Who needs to act next
  dueDate         DateTime?        @map("due_date") @db.Date
  submittedDate   DateTime?        @map("submitted_date") @db.Date
  responseDate    DateTime?        @map("response_date") @db.Date
  createdById     String           @map("created_by_id") @db.Uuid
  assignedToId    String?          @map("assigned_to_id") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    User    @relation("SubmittalCreator", fields: [createdById], references: [id])
  assignedTo   User?   @relation("SubmittalAssignee", fields: [assignedToId], references: [id])

  @@map("submittals")
}

enum SubmittalType {
  SUBMITTAL
  RFI
}

enum SubmittalStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  RESUBMIT
  CLOSED
}

// ── Plant Schedule ───────────────────────────────────────────────────

model PlantEntry {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  botanicalName   String   @map("botanical_name")
  commonName      String   @map("common_name")
  size            String?  // e.g., "24" box", "5 gal", "#15"
  quantity        Int      @default(1)
  spacing         String?  // e.g., "6' O.C."
  waterUse        String?  @map("water_use") // LOW, MODERATE, HIGH
  unitCost        Decimal? @map("unit_cost") @db.Decimal(10, 2)
  notes           String?
  substitution    String?  // Approved substitute plant
  approvalStatus  PlantApprovalStatus? @map("approval_status")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("plant_entries")
}

enum PlantApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Compliance Tracker ──────────────────────────────────────────────

model ComplianceItem {
  id                 String           @id @default(uuid()) @db.Uuid
  projectId          String           @map("project_id") @db.Uuid
  organizationId     String           @map("organization_id") @db.Uuid
  category           String           // MWELO, LEED, SITES, ADA, PERMIT, OTHER
  name               String
  description        String?
  status             ComplianceStatus @default(NOT_STARTED)
  dueDate            DateTime?        @map("due_date") @db.Date
  documentUrl        String?          @map("document_url")
  notes              String?
  // For MWELO items: stores the calculator inputs and outputs.
  // Shape: { region, specialLandscapeArea, hydrozones[], mawa, etwu, passes }
  // Only used when category = "MWELO"; null for other categories.
  mweloCalculation   Json?            @map("mwelo_calculation")
  // Soft-archive timestamp. Archived items stay in the DB (preserves
  // audit history for older calc revisions) but are hidden from default
  // list views. Use the `?archived=1` filter to see them again.
  archivedAt         DateTime?        @map("archived_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("compliance_items")
}

enum ComplianceStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
  N_A
}

// ── Phase Staff Plan (Work Plan) ─────────────────────────────────────
// Links staff to specific phases with planned hours. This is the "Work Plan"
// — the owner's plan for who works on each phase and for how many hours.

model PhaseStaffPlan {
  id            String   @id @default(uuid()) @db.Uuid
  phaseId       String   @map("phase_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  plannedHours  Decimal  @map("planned_hours") @db.Decimal(8, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  phase ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([phaseId, userId])
  @@map("phase_staff_plans")
}

enum PhaseType {
  PRE_DESIGN
  SCHEMATIC_DESIGN
  DESIGN_DEVELOPMENT
  CONSTRUCTION_DOCUMENTS
  BIDDING
  CONSTRUCTION_ADMIN
  CLOSEOUT
  OTHER // For fully custom phase types
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

// ── Time Entries ──────────────────────────────────────────────────────

model TimeEntry {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  projectId       String?  @map("project_id") @db.Uuid
  phaseId         String?  @map("phase_id") @db.Uuid
  leaveType       LeaveType? @map("leave_type")
  overheadCategory OverheadCategory? @map("overhead_category")
  date            DateTime @db.Date
  hours           Decimal  @db.Decimal(5, 2)
  description     String?
  isBillable      Boolean  @default(true) @map("is_billable")
  // Set when this entry is rolled into an invoice line item, so it
  // doesn't get pulled into a future invoice and double-billed. Cleared
  // when the invoice is deleted.
  invoiceId       String?  @map("invoice_id") @db.Uuid
  invoicedAt      DateTime? @map("invoiced_at")
  createdAt       DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase        ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId, date])
  @@index([projectId, phaseId])
  @@index([userId, date])
  @@index([userId, leaveType, date])
  @@index([userId, overheadCategory, date])
  @@index([invoiceId])
  @@map("time_entries")
}

enum OverheadCategory {
  GENERAL_ADMIN
  MARKETING
  PROFESSIONAL_DEVELOPMENT
  MEETINGS
  BUSINESS_DEVELOPMENT
  IT_EQUIPMENT
}

enum LeaveType {
  VACATION
  SICK
  HOLIDAY
  UNPAID
  OTHER
}

// ── Weekly Timesheets ─────────────────────────────────────────────────

model WeeklyTimesheet {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @map("user_id") @db.Uuid
  weekStart    DateTime        @map("week_start") @db.Date
  status       TimesheetStatus @default(DRAFT)
  submittedAt  DateTime?       @map("submitted_at")
  approvedById String?         @map("approved_by_id") @db.Uuid
  approvedAt   DateTime?       @map("approved_at")
  createdAt    DateTime        @default(now()) @map("created_at")

  user       User  @relation(fields: [userId], references: [id])
  approvedBy User? @relation("TimesheetApprover", fields: [approvedById], references: [id])

  @@unique([userId, weekStart])
  @@map("weekly_timesheets")
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

// ── Invoices ─────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  projectId       String        @map("project_id") @db.Uuid
  invoiceNumber   String        @map("invoice_number")
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime      @map("issue_date") @db.Date
  dueDate         DateTime      @map("due_date") @db.Date
  subtotal        Decimal       @db.Decimal(12, 2)
  tax             Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paidDate        DateTime?     @map("paid_date") @db.Date
  // Time period the invoice covers — drives the "For Professional
  // Services from X to Y" letterhead line and determines which
  // timesheet entries auto-populate the line items.
  periodStart     DateTime?     @map("period_start") @db.Date
  periodEnd       DateTime?     @map("period_end") @db.Date
  // Payment metadata captured by Mark-as-Paid: check number, ACH
  // reference, etc. paymentMethod is free text (Check / ACH / Wire / …).
  paymentReference String?      @map("payment_reference")
  paymentMethod    String?      @map("payment_method")
  sentAt          DateTime?     @map("sent_at")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems    InvoiceLineItem[]
  timeEntries  TimeEntry[]

  @@index([organizationId, status])
  @@index([projectId])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(uuid()) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  description String
  quantity    Decimal @db.Decimal(8, 2)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  amount      Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

// Recorded by the monthly auto-invoicing cron (and any future manual
// "run billing for this period" action). Lets the project Billing
// section show "Skipped Feb 2026 — no billable hours" so users know
// nothing fell through the cracks.
model BillingEvent {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  projectId      String           @map("project_id") @db.Uuid
  periodStart    DateTime         @map("period_start") @db.Date
  periodEnd      DateTime         @map("period_end") @db.Date
  kind           BillingEventKind
  note           String?
  createdAt      DateTime         @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // One event per project per period — guarantees the cron is idempotent.
  @@unique([projectId, periodStart, kind])
  @@index([organizationId, periodStart])
  @@map("billing_events")
}

enum BillingEventKind {
  SKIPPED_NO_HOURS
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  VOID
}

// ── Budget Alerts ─────────────────────────────────────────────────────
// One row per (project, alertLevel) pair. The unique constraint is what
// prevents the same threshold-crossing email from being sent twice. When
// a project's burn rate first crosses 75%, 90%, or 100%, we attempt to
// insert the row; on conflict we skip the email.
model BudgetAlert {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  alertLevel String   @map("alert_level") // WARNING_75 | CRITICAL_90 | OVER_100
  sentAt     DateTime @default(now()) @map("sent_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, alertLevel])
  @@map("budget_alerts")
}

// ── Stripe Webhook Idempotency ────────────────────────────────────────
// Tracks every Stripe event we've successfully accepted so retries (which
// Stripe issues on 5xx and timeouts) don't double-process the same event.
model ProcessedStripeEvent {
  id            String   @id @default(uuid()) @db.Uuid
  stripeEventId String   @unique @map("stripe_event_id")
  eventType     String   @map("event_type")
  processedAt   DateTime @default(now()) @map("processed_at")

  @@map("processed_stripe_events")
}
